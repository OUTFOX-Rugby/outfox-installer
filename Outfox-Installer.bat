@echo off
setlocal EnableExtensions
title Outfox Controller Fix

rem --- Self-elevate -----------------------------------------------------------
>nul 2>&1 net session
if errorlevel 1 (
    echo.
    echo  This fix needs administrator access.
    echo  Please click YES on the next prompt...
    powershell -NoProfile -Command "Start-Process -FilePath '%~f0' -Verb RunAs" >nul 2>&1
    if errorlevel 1 (
        echo.
        echo  Administrator access was declined. Nothing was changed.
        echo  Please run this file again and click YES on the prompt.
        echo.
        pause
    )
    exit /b
)

rem --- Extract embedded payload ------------------------------------------------
set "WORK=%TEMP%\OutfoxFix"
echo  Preparing, please wait...
powershell -NoProfile -ExecutionPolicy Bypass -Command "$ErrorActionPreference='Stop'; $f='%~f0'; $w='%WORK%'; $lines=[IO.File]::ReadAllLines($f); $i=[Array]::IndexOf($lines,'::PAYLOAD::'); if($i -lt 0){throw 'payload marker missing'}; $b64=(($lines[($i+1)..($lines.Length-1)] | ForEach-Object { $_.Trim() }) -join ''); if(Test-Path $w){Remove-Item $w -Recurse -Force}; New-Item -ItemType Directory -Path $w -Force | Out-Null; [IO.File]::WriteAllBytes((Join-Path $w 'payload.zip'),[Convert]::FromBase64String($b64)); Expand-Archive -Path (Join-Path $w 'payload.zip') -DestinationPath $w -Force"
if errorlevel 1 (
    echo.
    echo  Could not prepare the fix files.
    echo  Please photograph this window and send it to Outfox support.
    echo.
    pause
    exit /b 1
)

rem --- Run the fix ---------------------------------------------------------------
powershell -NoProfile -ExecutionPolicy Bypass -File "%WORK%\Run-ClientFix.ps1"
echo.
pause
exit /b
::PAYLOAD::




































































